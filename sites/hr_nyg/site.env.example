SITE=noryangjin_station
SITE_NAME=하나로마트 노량진점

# ===== Serial/Modbus =====
SERIAL_PORT=/dev/serial/by-id/REPLACE_ME
BAUD_RATE=9600
PARITY=N
STOPBITS=1
TIMEOUT=1.0
DELAY=0.15

# 장비 주소 (현장 확인 후 입력)
ADDRESSES=

# ===== Database =====
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ems
DB_USER=ems
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ===== Collection =====
COLLECTION_INTERVAL=5
SYNC_INTERVAL=3
AGG_INTERVAL=60

# ===== API =====
API_PORT=8001
API_KEY=REPLACE_WITH_STRONG_PASSWORD

# ===== Telegram Alarm (Optional) =====
TG_BOT_TOKEN=
TG_CHAT_ID=
